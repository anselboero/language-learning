# Copy to .env (or export in your shell) before running the service.
# The anthropic SDK reads ANTHROPIC_API_KEY automatically.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override where the local SQLite file lives.
# GRAMMAR_DB_PATH=./grammar.db

# Optional: model used for Reading ingestion (translate + align a book).
# This is the output-heavy, cost-dominant call; defaults to Sonnet to keep it
# cheap. Grammar features stay on Opus regardless. Use claude-haiku-4-5 for the
# cheapest runs, or claude-opus-4-8 for the highest-quality alignment.
# READING_MODEL=claude-sonnet-4-6
